generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STUDENT
  PAID_STUDENT
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SharedCaseStatus {
  PUBLISHED
  UNPUBLISHED
}

model User {
  id                    String         @id @default(cuid())
  username              String         @unique
  passwordHash          String
  role                  UserRole       @default(STUDENT)
  status                UserStatus     @default(ACTIVE)
  sharedAccessUntil     DateTime?
  sharedAccessPermanent Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  personalCases     PersonalCase[]
  submissions       Submission[]
  reviewedSubmits   Submission[]   @relation("ReviewedBy")
  rewards           AccessReward[]
}

model PersonalCase {
  id                   String       @id @default(cuid())
  userId               String
  title                String
  category             String?
  tags                 String[]
  summary              String?
  content              String
  question             String?
  caseType             String?
  caseTypeCustom       String?
  background           String?
  cardsAndClarifiers   String?
  spreadType           String?
  spreadTypeCustom     String?
  readingMethod        String?
  readingMethodCustom  String?
  feedback             String?
  detailedAnalysis     String?
  isSubmitted          Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  deletedAt            DateTime?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([userId])
}

model Submission {
  id             String           @id @default(cuid())
  personalCaseId String
  userId         String
  status         SubmissionStatus @default(PENDING)
  reviewNote     String?
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  personalCase   PersonalCase     @relation(fields: [personalCaseId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy     User?            @relation("ReviewedBy", fields: [reviewedById], references: [id])
  sharedCase     SharedCase?
  reward         AccessReward?

  @@index([userId])
  @@index([personalCaseId])
  @@index([status])
}

model SharedCase {
  id                   String           @id @default(cuid())
  sourceSubmissionId   String           @unique
  sourcePersonalCaseId String
  sourceUserId         String
  title                String
  category             String?
  tags                 String[]
  summary              String?
  content              String
  status               SharedCaseStatus @default(PUBLISHED)
  publishedAt          DateTime         @default(now())
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  submission           Submission       @relation(fields: [sourceSubmissionId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([sourceUserId])
}

model AccessReward {
  id           String   @id @default(cuid())
  userId       String
  submissionId String   @unique
  rewardDays   Int
  beforeUntil  DateTime?
  afterUntil   DateTime?
  createdAt    DateTime @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([userId])
}
